<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Primary" Color="#2563EB" />
    <SolidColorBrush x:Key="Brush.PrimaryHover" Color="#1447e6" />
    <SolidColorBrush x:Key="Brush.PrimarySelected" Color="#eff6ff" />
    <SolidColorBrush x:Key="Brush.Black" Color="#111827" />
    <SolidColorBrush x:Key="Brush.White" Color="White" />
    <SolidColorBrush x:Key="Brush.SubduedWhite" Color="#EFF6FF" />
    <SolidColorBrush x:Key="Brush.DarkGrey" Color="#6B7280" />
    <SolidColorBrush x:Key="Brush.LightGrey" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Brush.LighterGrey" Color="#f3f4f6" />
    <SolidColorBrush x:Key="Brush.LightestGrey" Color="#f9fafb" />

