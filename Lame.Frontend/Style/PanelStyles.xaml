<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.White}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.LightGrey}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0 16"/>
    </Style>
    
    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.SubduedWhite}"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="10, 4"/>
    </Style>
    
    <Style x:Key="SectionLineBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource Brush.LightGrey}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Margin" Value="0,16,0,0"/>
        <Setter Property="Padding" Value="0,16,0,0"/>
    </Style>
</ResourceDictionary>