<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Black}"/>
        <Setter Property="Margin" Value="8"/>
    </Style>
    
    <Style x:Key="Header1" TargetType="TextBlock" BasedOn="{StaticResource Body}">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0, 8"/>
    </Style>
    
    <Style x:Key="Header2" TargetType="TextBlock" BasedOn="{StaticResource Body}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0, 10"/>
    </Style>
    
    <Style x:Key="Header3" TargetType="TextBlock" BasedOn="{StaticResource Body}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0, 12"/>
    </Style>
    
    <Style x:Key="Subtitle" TargetType="TextBlock" BasedOn="{StaticResource Body}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.DarkGrey}"/>
    </Style>
</ResourceDictionary>