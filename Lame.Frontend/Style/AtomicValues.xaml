<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <sys:Double x:Key="Padding.Standard">24</sys:Double>
    <sys:Double x:Key="Padding.Medium">16</sys:Double>
    <sys:Double x:Key="Padding.Small">8</sys:Double>

    <sys:Double x:Key="Margin.Standard">16</sys:Double>
    <sys:Double x:Key="Margin.Small">8</sys:Double>
    
    <sys:Double x:Key="CornerRadius.Standard">8</sys:Double>
    <sys:Double x:Key="CornerRadius.Rounded">16</sys:Double>
    
    <sys:Double x:Key="BorderThickness.Standard">1</sys:Double>
    <sys:Double x:Key="BorderThickness.Thick">3</sys:Double>
    
    <Thickness x:Key="ButtonPadding" Bottom="12" Top="12" Left="24" Right="24"/>
</ResourceDictionary>