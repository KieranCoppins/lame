<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:Lame.Frontend.Helpers">
    <Style x:Key="ClickableText" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter 
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="NavigationButton"  TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0, 4"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius">
                                    <Setter.Value>
                                        <CornerRadius BottomLeft="{StaticResource CornerRadius.Standard}"
                                                      TopLeft="{StaticResource CornerRadius.Standard}"
                                                      TopRight="{StaticResource CornerRadius.Standard}"
                                                      BottomRight="{StaticResource CornerRadius.Standard}"/>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Border.Style>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root"
                                    Property="Background"
                                    Value="{StaticResource Brush.LighterGrey}"/>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root"
                                    Property="Background"
                                    Value="{StaticResource Brush.PrimarySelected}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="StyledButton" TargetType="Button">
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}"/>
        <Setter Property="Margin">
            <Setter.Value> 
                <Thickness Left="0" 
                           Top="0" 
                           Right="{StaticResource Margin.Small}" 
                           Bottom="{StaticResource Margin.Small}"/> 
            </Setter.Value> 
        </Setter>
        <Setter Property="Background" Value="{StaticResource Brush.White}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Black}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.LightGrey}"/>
        
        <Setter Property="helpers:ButtonHelpers.HoverBackground" Value="{StaticResource Brush.LighterGrey}"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius">
                                    <Setter.Value>
                                        <CornerRadius BottomLeft="{StaticResource CornerRadius.Standard}"
                                                      TopLeft="{StaticResource CornerRadius.Standard}"
                                                      TopRight="{StaticResource CornerRadius.Standard}"
                                                      BottomRight="{StaticResource CornerRadius.Standard}"/>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Border.Style>
                        <ContentPresenter 
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root"
                                    Property="Background"
                                    Value="{Binding RelativeSource={RelativeSource TemplatedParent}, 
                                        Path=(helpers:ButtonHelpers.HoverBackground)}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource StyledButton}">
        <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.White}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="helpers:ButtonHelpers.HoverBackground" Value="{StaticResource Brush.PrimaryHover}"/>
    </Style>
    
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource StyledButton}">
        
    </Style>
</ResourceDictionary>