<UserControl x:Class="Lame.Frontend.Views.Exports.ExportXliffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:exports="clr-namespace:Lame.Frontend.ViewModels.Exports"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             xmlns:domainModel="clr-namespace:Lame.DomainModel;assembly=Lame.DomainModel"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="720"
             d:DataContext="{d:DesignInstance exports:ExportXliffViewModel  }">
    <UserControl.Resources>
        <CollectionViewSource x:Key="FilteredLanguages"
                              Source="{Binding ExportViewModel.AvailableLanguages}" />
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Target language"
                   Style="{StaticResource Header2}" />
        <TextBlock Text="Source language is always English. Select the target language for the XLIFF export."
                   Style="{StaticResource Subtitle}"
                   FontSize="12" />
        <ComboBox ItemsSource="{Binding Source={StaticResource FilteredLanguages}}"
                  SelectedItem="{Binding TargetLanguage}"
                  Style="{StaticResource BlankComboBox}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock
                        Text="{Binding LanguageCode, Converter={StaticResource LanguageCodeToEnglishConverter}}"
                        Style="{StaticResource Body}"
                        Margin="0" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Translation Status Filter"
                   Style="{StaticResource Header2}" />

        <controls:DescriptiveRadioButton
            IsChecked="{Binding TranslationStatusFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static domainModel:ExportTranslationStatusFilter.All}}"
            Command="{Binding SetTranslationStatusFilterCommand}"
            CommandParameter="{x:Static domainModel:ExportTranslationStatusFilter.All}"
            TitleText="All Translations"
            BodyText="Export all assets regardless of translation status" />

        <controls:DescriptiveRadioButton
            IsChecked="{Binding TranslationStatusFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static domainModel:ExportTranslationStatusFilter.Complete}}"
            Command="{Binding SetTranslationStatusFilterCommand}"
            CommandParameter="{x:Static domainModel:ExportTranslationStatusFilter.Complete}"
            TitleText="Complete Translations Only"
            BodyText="Export only assets with completed translations" />

        <controls:DescriptiveRadioButton
            IsChecked="{Binding TranslationStatusFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static domainModel:ExportTranslationStatusFilter.Missing}}"
            Command="{Binding SetTranslationStatusFilterCommand}"
            CommandParameter="{x:Static domainModel:ExportTranslationStatusFilter.Missing}"
            TitleText="Missing Translations Only"
            BodyText="Export only assets that need translation" />

        <Border Style="{StaticResource SectionLineBorderStyle}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <WrapPanel Margin="0, 4">
                    <TextBlock Text="Format: "
                               Style="{StaticResource Subtitle}"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0, 0, 4, 0" />
                    <TextBlock Text="Xliff 1.2"
                               Style="{StaticResource Subtitle}"
                               FontSize="12"
                               Margin="0"
                               VerticalAlignment="Center" />
                </WrapPanel>
                <WrapPanel Margin="0, 4">
                    <TextBlock Text="Source: "
                               Style="{StaticResource Subtitle}"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0, 0, 4, 0" />
                    <TextBlock Text="English"
                               Style="{StaticResource Subtitle}"
                               FontSize="12"
                               Margin="0"
                               VerticalAlignment="Center" />
                </WrapPanel>
                <WrapPanel Margin="0, 4">
                    <TextBlock Text="Target: "
                               Style="{StaticResource Subtitle}"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0, 0, 4, 0" />
                    <TextBlock
                        Text="{Binding TargetLanguage.LanguageCode, Converter={StaticResource LanguageCodeToEnglishConverter}}"
                        Style="{StaticResource Subtitle}"
                        FontSize="12"
                        Margin="0"
                        VerticalAlignment="Center" />
                </WrapPanel>
                <WrapPanel Margin="0, 4">
                    <TextBlock Text="Translation Filter: "
                               Style="{StaticResource Subtitle}"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0, 0, 4, 0" />
                    <TextBlock
                        Text="{Binding TranslationStatusFilter}"
                        Style="{StaticResource Subtitle}"
                        FontSize="12"
                        Margin="0"
                        VerticalAlignment="Center" />
                </WrapPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource PrimaryButton}"
                    Content="Export XLIFF"
                    VerticalAlignment="Center"
                    Command="{Binding ExportViewModel.ExportCommand}"
                    Margin="0" />
        </Grid>
    </StackPanel>
</UserControl>