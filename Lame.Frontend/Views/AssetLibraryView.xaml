<UserControl x:Class="Lame.Frontend.Views.AssetLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="720"
             d:DataContext="{d:DesignInstance Type=viewModels:AssetLibraryViewModel}">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Background="{StaticResource Brush.LightestGrey}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Style="{StaticResource SectionStyle}">
                    <TextBlock Text="Asset Library"
                               Style="{StaticResource Header1}" />
                    <TextBlock Text="Browse and manage your localization assets"
                               Style="{StaticResource Subtitle}"
                               Margin="0" />
                </StackPanel>

                <!-- Search bar -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <TextBox Text="{Binding SearchQuery, Delay=500, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledInputBox}"
                             Background="{StaticResource Brush.LighterGrey}"
                             helpers:TextBoxHelpers.Placeholder="Search assets by name or tag..." />
                </Border>

                <!-- Assets Library Table -->
                <StackPanel>
                    <DataGrid ItemsSource="{Binding Assets}"
                              Style="{StaticResource DataTable}"
                              PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Asset" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding InternalName}"
                                                   Style="{StaticResource Body}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Type" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding AssetType}"
                                                   Style="{StaticResource Body}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Progress" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ProgressBar Grid.Column="0"
                                                         Style="{StaticResource ProgressBarStyle}"
                                                         Maximum="100">
                                                <ProgressBar.Value>
                                                    <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                        <Binding Path="NumTranslations" />
                                                        <Binding Path="DataContext.SupportedLanguagesCount"
                                                                 RelativeSource="{RelativeSource AncestorType=DataGrid}"
                                                                 Mode="OneWay" />
                                                    </MultiBinding>
                                                </ProgressBar.Value>
                                            </ProgressBar>

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Body}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}/{1}">
                                                        <Binding Path="NumTranslations" />
                                                        <Binding Path="DataContext.SupportedLanguagesCount"
                                                                 RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Last Modified"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding LastUpdatedAt, Converter={StaticResource DateConverter}}"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource Body}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Actions" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ClickableText}"
                                                Command="{Binding DataContext.ViewAssetDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="View Details"
                                                       Style="{StaticResource Link}" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <controls:PageNavigationControl CurrentPage="{Binding CurrentPage}"
                                                    PageCommand="{Binding SetPageCommand}"
                                                    PageNumbers="{Binding PageNumbers}" />

                    <Control HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Margin="16">
                        <Control.Style>
                            <Style TargetType="Control" BasedOn="{StaticResource SpinnerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Control.Style>
                    </Control>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>