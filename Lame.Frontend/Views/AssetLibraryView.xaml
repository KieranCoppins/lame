<UserControl x:Class="Lame.Frontend.Views.AssetLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             d:DataContext="{d:DesignInstance Type=viewModels:AssetLibraryViewModel}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel>
                <TextBlock Text="Asset Library"
                           Style="{StaticResource Header1}" />
                <TextBlock Text="Browse and manage your localization assets"
                           Style="{StaticResource Subtitle}"
                           Margin="0" />
            </StackPanel>

            <!-- Search bar -->
            <Border Style="{StaticResource CardBorderStyle}">
                <TextBox Style="{StaticResource BlankInput}"
                         helpers:TextBoxHelpers.Placeholder="Search assets..." />
            </Border>

            <!-- Assets Library Table -->
            <StackPanel>
                <DataGrid ItemsSource="{Binding Assets}"
                          Style="{StaticResource DataTable}"
                          PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Asset" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding InternalName}"
                                               Style="{StaticResource Body}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Type" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AssetType}"
                                               Style="{StaticResource Body}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Progress" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Progress}"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource Body}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Last Modified"
                                                Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LastModified}"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource Body}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Actions" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ClickableText}"
                                            Command="{Binding DataContext.ViewAssetDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="View Details"
                                                   Style="{StaticResource Link}" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
                <Control HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="16">
                    <Control.Style>
                        <Style TargetType="Control" BasedOn="{StaticResource SpinnerStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Control.Style>
                </Control>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>