<UserControl x:Class="Lame.Frontend.Views.AssetSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1920" d:DesignWidth="1080"
             d:DataContext="{d:DesignInstance viewModels:AssetSyncViewModel }">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Background="{StaticResource Brush.LightestGrey}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Style="{StaticResource SectionStyle}">
                    <TextBlock Text="Asset Links"
                               Style="{StaticResource Header1}" />
                    <TextBlock
                        Text="View all of the asset links in your project and their sync status. Review asset links to mark them as synced."
                        Style="{StaticResource Subtitle}"
                        Margin="0" />

                    <StackPanel Margin="0, 16, 0, 0">
                        <DataGrid ItemsSource="{Binding AssetLinks}"
                                  Style="{StaticResource DataTable}"
                                  PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Asset" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Asset.InternalName}"
                                                       Style="{StaticResource Body}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Linked Asset" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LinkedAsset.InternalName}"
                                                       Style="{StaticResource Body}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Synced" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Synced}"
                                                       Style="{StaticResource Body}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Actions" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ClickableText}"
                                                    Command="{Binding DataContext.ReviewAssetLinkCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="Review"
                                                           Style="{StaticResource Link}" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <controls:PageNavigationControl CurrentPage="{Binding CurrentPage}"
                                                        PageCommand="{Binding SetPageCommand}"
                                                        PageNumbers="{Binding PageNumbers}" />

                        <Control HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="16">
                            <Control.Style>
                                <Style TargetType="Control" BasedOn="{StaticResource SpinnerStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Control.Style>
                        </Control>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>