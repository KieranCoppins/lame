<UserControl x:Class="Lame.Frontend.Views.CreateAssetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             d:DataContext="{d:DesignInstance Type=viewModels:CreateAssetViewModel}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Create Asset"
                           Style="{StaticResource Header1}" />
                <TextBlock Text="Add a new english localization asset to your project"
                           Style="{StaticResource Subtitle}"
                           Margin="0" />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Basic Information"
                               Style="{StaticResource Header2}" />

                    <TextBlock Style="{StaticResource FieldLabel}">
                        <Run>Internal Name</Run>
                        <Run Foreground="{StaticResource Brush.NotificationFailure}">*</Run>
                    </TextBlock>
                    <TextBox Style="{StaticResource BlankInput}"
                             Text="{Binding InternalName,
                                 ValidatesOnNotifyDataErrors=True,
                                 UpdateSourceTrigger=PropertyChanged}"
                             helpers:TextBoxHelpers.Placeholder="e.g. ui_main_menu_title" />

                    <TextBlock Text="Asset Type"
                               Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="AssetTypeComboBox"
                              Style="{StaticResource BlankComboBox}"
                              ItemTemplate="{StaticResource TextComboBoxItemTemplate}"
                              ItemsSource="{Binding AssetTypes}"
                              SelectedItem="{Binding SelectedAssetType}" />

                    <TextBlock Text="Tags"
                               Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource BlankInput}"
                             Text="{Binding Tags}"
                             helpers:TextBoxHelpers.Placeholder="e.g. main-menu, chapter-1, intro" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="English Translation"
                               Style="{StaticResource Header2}" />
                    <TextBlock
                        Text="An english translation is needed to create the asset, but you can change it later if needed."
                        Style="{StaticResource Subtitle}"
                        Margin="0" />

                    <TextBlock Style="{StaticResource FieldLabel}">
                        <Run>Content</Run>
                        <Run Foreground="{StaticResource Brush.NotificationFailure}">*</Run>
                    </TextBlock>
                    <TextBox Style="{StaticResource BlankInput}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             MinHeight="60"
                             helpers:TextBoxHelpers.Placeholder="Enter UI text or label..."
                             Text="{Binding EnglishContent,
                                 ValidatesOnNotifyDataErrors=True,
                                 UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Notes / Context"
                               Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource BlankInput}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             MinHeight="60"
                             helpers:TextBoxHelpers.Placeholder="Add context for translators..."
                             Text="{Binding ContextNotes}" />
                </StackPanel>
            </Border>

            <WrapPanel>
                <Button Content="Create Asset"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateAssetCommand}"
                        helpers:CommonHelpers.IsLoading="{Binding CreatingAsset}" />
                <Button Content="Clear Form"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearFormCommand}" />
            </WrapPanel>
        </StackPanel>
    </Grid>
</UserControl>