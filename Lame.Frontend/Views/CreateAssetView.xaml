<UserControl x:Class="Lame.Frontend.Views.CreateAssetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Lame.Frontend.Views"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Brush.LightestGrey}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Create Asset"
                               Style="{StaticResource Header1}"/>
                    <TextBlock Text="Add a new english localization asset to your project"
                               Style="{StaticResource Subtitle}"
                               Margin="0"/>
                </StackPanel>
                
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Basic Information"
                                   Style="{StaticResource Header2}"/>
                        
                        <TextBlock Text="Internal Name"
                                   Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBox}"
                                Background="{StaticResource Brush.White}">
                            <TextBox Style="{StaticResource BlankInput}"
                                     helpers:TextBoxHelpers.Placeholder="e.g. ui_main_menu_title"/>
                        </Border>
                        
                        <TextBlock Text="Asset Type"
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="AssetTypeComboBox"
                                  Style="{StaticResource BlankComboBox}"
                                  ItemTemplate="{StaticResource TextComboBoxItemTemplate}"/>
                        
                        <TextBlock Text="Tags"
                                   Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBox}"
                                Background="{StaticResource Brush.White}">
                            <TextBox Style="{StaticResource BlankInput}"
                                     helpers:TextBoxHelpers.Placeholder="e.g. main-menu, chapter-1, intro"/>
                        </Border>
                    </StackPanel>
                </Border>
                
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="English Translation"
                                   Style="{StaticResource Header2}"/>
                        <TextBlock Text="An english translation is needed to create the asset, but you can change it later if needed."
                                   Style="{StaticResource Subtitle}"
                                   Margin="0"/>
                        
                        <TextBlock Text="Content"
                                   Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBox}"
                                Background="{StaticResource Brush.White}">
                            <TextBox Style="{StaticResource BlankInput}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     MinHeight="60"
                                     helpers:TextBoxHelpers.Placeholder="Enter UI text or label..."/>
                        </Border>
                        
                        <TextBlock Text="Notes / Context"
                                   Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBox}"
                                Background="{StaticResource Brush.White}">
                            <TextBox Style="{StaticResource BlankInput}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     MinHeight="60"
                                     helpers:TextBoxHelpers.Placeholder="Add context for translators..."/>
                        </Border>
                    </StackPanel>
                </Border>
                
                <WrapPanel>
                    <Button Content="Create Asset"
                            Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Clear Form"
                            Style="{StaticResource SecondaryButton}"/>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
