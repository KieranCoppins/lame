<UserControl x:Class="Lame.Frontend.Views.Dialogs.ArchiveAssetDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels.Dialogs"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance viewModels:ArchiveAssetDialogViewModel}">
    <controls:ConfirmationDialogControl
        Title="Archive Asset"
        Body="Are you sure you want to archive this asset?"
        PrimaryButtonLabel="Archive Asset"
        PrimaryButtonColour="{StaticResource Brush.NotificationFailure}"
        PrimaryButtonHoverColour="{StaticResource Brush.NotificationFailureHover}"
        PrimaryCommand="{Binding ArchiveCommand}"
        SecondaryCommand="{Binding CloseCommand}"
        IsLoading="{Binding IsLoading}" />
</UserControl>