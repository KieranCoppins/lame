<UserControl x:Class="Lame.Frontend.Views.Dialogs.AddSupportedLanguageDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialogViewModels="clr-namespace:Lame.Frontend.ViewModels.Dialogs"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance dialogViewModels:AddSupportedLanguageDialogViewModel }">

    <StackPanel>
        <TextBlock Text="Add New Language"
                   Style="{StaticResource Header2}" />

        <controls:DynamicLoadingComboBox
            SelectedItem="{Binding SelectedLanguage}"
            ContentSearch="{Binding SearchLanguages}"
            Placeholder="Search languages...">
            <controls:DynamicLoadingComboBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   Style="{StaticResource Body}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LanguageCode}"
                                   Style="{StaticResource Subtitle}"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </controls:DynamicLoadingComboBox.ItemTemplate>
        </controls:DynamicLoadingComboBox>

        <WrapPanel HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButton}" />
            <Button Content="Add Language"
                    Command="{Binding AddLanguageCommand}"
                    helpers:CommonHelpers.IsLoading="{Binding IsAddingLanguage}"
                    Style="{StaticResource PrimaryButton}" />
        </WrapPanel>
    </StackPanel>
</UserControl>