<UserControl x:Class="Lame.Frontend.Views.Dialogs.EditTranslationDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels.Dialogs"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance viewModels:EditTranslationDialogViewModel}">
    <StackPanel>
        <TextBlock Style="{StaticResource Header2}">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}Edit {0} Translation">
                    <Binding Path="Translation.Language"
                             Converter="{StaticResource LanguageCodeToEnglishConverter}" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Text="Version"
                   Style="{StaticResource FieldLabel}" />
        <ComboBox Style="{StaticResource BlankComboBox}"
                  ItemsSource="{Binding Translations}"
                  SelectedItem="{Binding SelectedTranslation}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Style="{StaticResource Body}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}v{0}.{1}">
                                <Binding Path="MajorVersion" />
                                <Binding Path="MinorVersion" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Content"
                   Style="{StaticResource FieldLabel}" />

        <controls:TranslationContentEditor
            TranslationContent="{Binding Content}"
            AssetType="{Binding OwningAsset.AssetType}" />


        <CheckBox Style="{StaticResource Body}"
                  IsChecked="{Binding HasMajorChanges}">
            <CheckBox.ToolTip>
                <TextBlock Style="{StaticResource Body}">
                    Increments the major version number of the translation when saved.
                    <LineBreak />
                    When updating old versions, it will match the latest english translation version.
                    <LineBreak />
                    Translations are marked as out of date when major versions mismatch.
                    <LineBreak />
                    If this is the first translation version, this setting will be ignored.
                </TextBlock>
            </CheckBox.ToolTip>

            <CheckBox.ContentTemplate>
                <DataTemplate>
                    <TextBlock Style="{StaticResource Body}"
                               Foreground="{StaticResource Brush.DarkGrey}"
                               TextWrapping="Wrap"
                               Margin="8, 0">

                        <Run Text="Contains major content changes" />

                        <InlineUIContainer BaselineAlignment="Center">
                            <Border Width="16"
                                    Height="16"
                                    Background="{StaticResource Brush.LightGrey}"
                                    CornerRadius="8"
                                    Cursor="Hand">
                                <TextBlock Text="?"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </InlineUIContainer>
                    </TextBlock>
                </DataTemplate>
            </CheckBox.ContentTemplate>
        </CheckBox>

        <WrapPanel HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}" />
            <Button Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveChangesCommand}"
                    helpers:CommonHelpers.IsLoading="{Binding IsSaving}" />
        </WrapPanel>
    </StackPanel>
</UserControl>