<UserControl x:Class="Lame.Frontend.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="720"
             d:DataContext="{d:DesignInstance Type=viewModels:DashboardViewModel}">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Background="{StaticResource Brush.LightestGrey}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Style="{StaticResource SectionStyle}">
                    <TextBlock Text="Dashboard"
                               Style="{StaticResource Header1}" />
                    <TextBlock Text="Overview of your localization project"
                               Style="{StaticResource Subtitle}"
                               Margin="0" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Total Assets"
                                       Style="{StaticResource Subtitle}"
                                       Margin="0" />
                            <TextBlock Text="{Binding ProjectStatistics.TotalAssets}"
                                       Style="{StaticResource Header1}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Languages Supported"
                                       Style="{StaticResource Subtitle}"
                                       Margin="0" />
                            <TextBlock Text="{Binding ProjectStatistics.TotalLanguages}"
                                       Style="{StaticResource Header1}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Missing Localizations"
                                       Style="{StaticResource Subtitle}"
                                       Margin="0" />
                            <TextBlock Text="{Binding ProjectStatistics.MissingTranslations}"
                                       Style="{StaticResource Header1}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Out of Sync Links"
                                       Style="{StaticResource Subtitle}"
                                       Margin="0" />
                            <TextBlock Text="{Binding ProjectStatistics.TotalOutOfSyncLinks}"
                                       Style="{StaticResource Header1}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>

                            <FrameworkElement x:Name="CompletedPercentageReference">
                                <FrameworkElement.Tag>
                                    <MultiBinding Converter="{StaticResource PercentageConverter}">
                                        <Binding Path="CompletedTranslations" Mode="OneWay" />
                                        <Binding Path="TotalTranslations" />
                                    </MultiBinding>
                                </FrameworkElement.Tag>
                            </FrameworkElement>

                            <TextBlock Text="Completed"
                                       Style="{StaticResource Subtitle}"
                                       Margin="0" />
                            <TextBlock Style="{StaticResource Header1}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}%">
                                        <Binding Path="Tag"
                                                 ElementName="CompletedPercentageReference" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Progress by Language"
                                       Style="{StaticResource Header2}" />
                            <ItemsControl ItemsSource="{Binding ProjectStatistics.TranslationsByLanguage}"
                                          Grid.IsSharedSizeScope="True">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0, 0, 0, 8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"
                                                                      SharedSizeGroup="Lang" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto"
                                                                      SharedSizeGroup="Percent" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Key, Converter={StaticResource LanguageCodeToEnglishConverter}}"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource Body}"
                                                           FontSize="13"
                                                           Margin="0" />

                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Style="{StaticResource Body}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource Brush.DarkGrey}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}/{1}">
                                                            <Binding Path="Value" />
                                                            <Binding Path="DataContext.ProjectStatistics.TotalAssets"
                                                                     RelativeSource="{ RelativeSource AncestorType=ItemsControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>

                                                <FrameworkElement x:Name="LanguagePercentageReference">
                                                    <FrameworkElement.Tag>
                                                        <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                            <Binding Path="Value" />
                                                            <Binding Path="DataContext.ProjectStatistics.TotalAssets"
                                                                     RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                        </MultiBinding>
                                                    </FrameworkElement.Tag>
                                                </FrameworkElement>

                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           Style="{StaticResource Body}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:F0}%">
                                                            <Binding Path="Tag"
                                                                     ElementName="LanguagePercentageReference" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>

                                            <ProgressBar
                                                Style="{StaticResource ProgressBarStyle}"
                                                Value="{Binding Value, Mode=OneWay}"
                                                Maximum="{Binding DataContext.ProjectStatistics.TotalAssets, 
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}" />

                                        </StackPanel>


                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Assets by Tag"
                                       Style="{StaticResource Header2}" />

                            <ItemsControl ItemsSource="{Binding ProjectStatistics.AssetsByTag}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Style="{StaticResource SmallSectionStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="5"
                                                    CornerRadius="2.5"
                                                    Background="{Binding Key.Id, 
                                                Converter={StaticResource GuidToColourConverter}}"
                                                    Margin="8, 0" />

                                            <StackPanel Grid.Column="1">
                                                <Button Style="{StaticResource ClickableText}"
                                                        Command="{Binding DataContext.SearchTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Key}">
                                                    <TextBlock Style="{StaticResource Link}"
                                                               Margin="0"
                                                               FontSize="13">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}#{0}">
                                                                <Binding Path="Key.Name" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Button>

                                                <FrameworkElement x:Name="TagPercentageReference">
                                                    <FrameworkElement.Tag>
                                                        <MultiBinding Converter="{StaticResource PercentageConverter}">
                                                            <Binding Path="Value" Mode="OneWay" />
                                                            <Binding
                                                                Path="DataContext.ProjectStatistics.TotalAssets"
                                                                RelativeSource="{RelativeSource AncestorType=ItemsControl}"
                                                                Mode="OneWay" />
                                                            <Binding Source="1" Mode="OneWay" />
                                                        </MultiBinding>
                                                    </FrameworkElement.Tag>
                                                </FrameworkElement>

                                                <TextBlock Style="{StaticResource Subtitle}"
                                                           Margin="0"
                                                           FontSize="11">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:F1}% of assets">
                                                            <Binding Path="Tag"
                                                                     ElementName="TagPercentageReference" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Value}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Header2}"
                                                       Margin="0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Recent Activity" Style="{StaticResource Header2}" />

                        <controls:ChangeLogControl Entries="{Binding Entries}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>