<UserControl x:Class="Lame.Frontend.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Lame.Frontend.Views"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Brush.LightestGrey}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel>
                <StackPanel>
                    <TextBlock Text="Dashboard"
                               Style="{StaticResource Header1}"/>
                    <TextBlock Text="Overview of your localization project"
                               Style="{StaticResource Subtitle}"
                               Margin="0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
