<UserControl x:Class="Lame.Frontend.Views.AssetDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             d:DataContext="{d:DesignInstance Type=viewModels:AssetDetailsViewModel}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <!-- Back Button -->
            <Button Command="{Binding ReturnToLibraryCommand}"
                    Style="{StaticResource ClickableText}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="← Back to Asset Library"
                               FontSize="14"
                               Style="{StaticResource Link}"
                               Foreground="{StaticResource Brush.Primary}" />
                </StackPanel>
            </Button>

            <!-- Header Card -->
            <Border Style="{StaticResource CardBorderStyle}">

                <StackPanel>
                    <!-- Top Section -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Section -->
                        <StackPanel Orientation="Horizontal" Grid.Column="0">

                            <!-- Title + Meta -->
                            <StackPanel>
                                <TextBlock Text="{Binding InternalName}" Style="{StaticResource Header1}" />

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,8,0,0">

                                    <TextBlock Text="Type: "
                                               Style="{StaticResource Subtitle}"
                                               Margin="0" />

                                    <TextBlock Text="{Binding AssetType}"
                                               Style="{StaticResource Subtitle}"
                                               Margin="0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Section (Progress) -->
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">

                            <TextBlock Text="{Binding Progress}"
                                       Style="{StaticResource Header1}"
                                       HorizontalAlignment="Right" />

                            <TextBlock Text="Complete"
                                       Style="{StaticResource Subtitle}"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>

                    <!-- Tags -->
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ChipBorderStyle}"
                                        Margin="0,0,8,8">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource Body}"
                                               Foreground="{StaticResource Brush.Primary}"
                                               Margin="0" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom Metadata Section -->
                    <Border Style="{StaticResource SectionLineBorderStyle}">

                        <UniformGrid Columns="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕒"
                                           Style="{StaticResource Body}"
                                           Margin="0,0,6,0" />
                                <TextBlock Style="{StaticResource Body}"
                                           Margin="0">
                                    <Run Text="Created on " />
                                    <Run Text="{Binding CreatedAt, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕒"
                                           Style="{StaticResource Body}"
                                           Margin="0,0,6,0" />
                                <TextBlock Style="{StaticResource Body}"
                                           Margin="0">
                                    <Run Text="Last modified " />
                                    <Run Text="{Binding LastModified, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Content Context" Style="{StaticResource Header2}" />

                    <TextBlock Text="{Binding ContentContext}" Style="{StaticResource Body}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Linked Assets" Style="{StaticResource Header2}" />

                    <TextBlock Text="No linked assets found."
                               FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Subtitle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LinkedAssets.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding LinkedAssets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{StaticResource Brush.LightestGrey}"
                                        Margin="0, 8">
                                    <StackPanel>
                                        <Button Style="{StaticResource ClickableText}"
                                                Command="{Binding DataContext.ViewLinkedAssetDetails, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding InternalName}"
                                                       Style="{StaticResource Link}"
                                                       FontSize="14"
                                                       Margin="0, 0, 0, 8" />
                                        </Button>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding LastModified}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                            <TextBlock Text="•"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="8, 0" />
                                            <TextBlock Text="{Binding AssetType}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                            <TextBlock Text="•"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="8, 0" />
                                            <TextBlock Text="{Binding Progress}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Style="{StaticResource SectionLineBorderStyle}">
                        <Button Style="{StaticResource ClickableText}"
                                Command="{Binding OpenLinkAssetDialogCommand}">
                            <TextBlock Text="Add New Link"
                                       Style="{StaticResource Link}"
                                       Foreground="{StaticResource Brush.Primary}" />
                        </Button>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Localizations" Style="{StaticResource Header2}" />

                    <ItemsControl ItemsSource="{Binding Translations}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{StaticResource Brush.LightestGrey}"
                                        Margin="0, 8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Language}"
                                                   Style="{StaticResource Header3}"
                                                   Margin="0, 0, 0, 8" />
                                        <WrapPanel>
                                            <TextBlock Text="{Binding CreatedAt}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                            <TextBlock Text="•"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="8, 0" />
                                            <TextBlock Text="{Binding Version}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />

                                        </WrapPanel>
                                        <TextBlock Text="{Binding Content}"
                                                   Style="{StaticResource Body}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>