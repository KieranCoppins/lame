<UserControl x:Class="Lame.Frontend.Views.AssetDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:controls="clr-namespace:Lame.Frontend.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920"
             d:DataContext="{d:DesignInstance Type=viewModels:AssetDetailsViewModel}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <!-- Back Button -->
            <Button Command="{Binding ReturnToLibraryCommand}"
                    Style="{StaticResource ClickableText}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="← Back to Asset Library"
                               FontSize="14"
                               Style="{StaticResource Link}"
                               Foreground="{StaticResource Brush.Primary}" />
                </StackPanel>
            </Button>

            <!-- Header Card -->
            <Border Style="{StaticResource CardBorderStyle}">

                <StackPanel>
                    <!-- Top Section -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Section -->
                        <StackPanel Grid.Column="0">

                            <!-- Title + Meta -->
                            <controls:EditableText
                                Text="{Binding InternalName}"
                                Style="{StaticResource Header1}" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,8,0,0">

                                <TextBlock Text="Type: "
                                           Style="{StaticResource Subtitle}"
                                           Margin="0" />

                                <TextBlock Text="{Binding Asset.AssetType}"
                                           Style="{StaticResource Subtitle}"
                                           Margin="0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Section (Progress) -->
                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Right">

                            <TextBlock Style="{StaticResource Header1}"
                                       HorizontalAlignment="Right"
                                       Margin="0">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource PercentageConverter}">
                                        <Binding Path="Asset.NumTranslations" />
                                        <Binding Path="SupportedLanguagesCount" />
                                        <Binding Source="0"
                                                 Mode="OneWay" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <TextBlock Text="Complete"
                                       Style="{StaticResource Subtitle}"
                                       HorizontalAlignment="Right"
                                       Margin="0" />
                        </StackPanel>
                    </Grid>

                    <!-- Tags -->
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ChipBorderStyle}"
                                        Background="{Binding Id, Converter={StaticResource GuidToColourConverter}}">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource Body}"
                                               Foreground="{StaticResource Brush.White}"
                                               Margin="0" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom Metadata Section -->
                    <Border Style="{StaticResource SectionLineBorderStyle}">

                        <UniformGrid Columns="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕒"
                                           Style="{StaticResource Subtitle}"
                                           Margin="0,0,6,0" />
                                <TextBlock Style="{StaticResource Subtitle}"
                                           Margin="0">
                                    <Run Text="Created on " />
                                    <Run Text="{Binding Asset.CreatedAt, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕒"
                                           Style="{StaticResource Subtitle}"
                                           Margin="0,0,6,0" />
                                <TextBlock Style="{StaticResource Subtitle}"
                                           Margin="0">
                                    <Run Text="Last modified " />
                                    <Run Text="{Binding Asset.LastUpdatedAt, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Content Context"
                               Style="{StaticResource Header2}" />

                    <controls:EditableText Text="{Binding ContextNotes}">
                        <controls:EditableText.Style>
                            <Style BasedOn="{StaticResource Body}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContextNotes}" Value="{x:Null}">
                                        <Setter Property="FrameworkElement.Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:EditableText.Style>
                    </controls:EditableText>

                    <TextBlock Text="No context provided."
                               Visibility="Collapsed"
                               FontStyle="Italic">
                        <TextBlock.Style>
                            <Style BasedOn="{StaticResource Subtitle}"
                                   TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Asset.ContextNotes}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Linked Assets" Style="{StaticResource Header2}" />

                    <TextBlock Text="No linked assets found."
                               FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Subtitle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LinkedAssets.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding LinkedAssets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{StaticResource Brush.LightestGrey}"
                                        Margin="0, 8">
                                    <StackPanel>
                                        <Button Style="{StaticResource ClickableText}"
                                                Command="{Binding DataContext.ViewLinkedAssetDetails, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding InternalName}"
                                                       Style="{StaticResource Link}"
                                                       FontSize="14"
                                                       Margin="0, 0, 0, 8" />
                                        </Button>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding LastModified}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                            <TextBlock Text="•"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="8, 0" />
                                            <TextBlock Text="{Binding AssetType}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                            <TextBlock Text="•"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="8, 0" />
                                            <TextBlock Text="{Binding Progress}"
                                                       Style="{StaticResource Subtitle}"
                                                       Margin="0" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Style="{StaticResource SectionLineBorderStyle}">
                        <Button Style="{StaticResource ClickableText}"
                                Command="{Binding OpenLinkAssetDialogCommand}">
                            <TextBlock Text="Add New Link"
                                       Style="{StaticResource Link}"
                                       Foreground="{StaticResource Brush.Primary}" />
                        </Button>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Localizations" Style="{StaticResource Header2}" />

                    <ItemsControl ItemsSource="{Binding Translations}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ContainerBorder"
                                        Style="{StaticResource SmallCardBorderStyle}"
                                        Background="{StaticResource Brush.LightestGrey}"
                                        BorderBrush="{StaticResource Brush.NotificationSuccess}"
                                        Margin="0, 8">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Language}"
                                                       Style="{StaticResource Header3}"
                                                       Margin="0, 0, 0, 8" />

                                            <WrapPanel Grid.Column="1"
                                                       HorizontalAlignment="Right"
                                                       x:Name="TranslationMetaPanel">
                                                <TextBlock Text="{Binding CreatedAt}"
                                                           Style="{StaticResource Subtitle}"
                                                           Margin="0" />
                                                <TextBlock Text="•"
                                                           Style="{StaticResource Subtitle}"
                                                           Margin="8, 0" />
                                                <TextBlock Text="{Binding Version}"
                                                           Style="{StaticResource Subtitle}"
                                                           Margin="0" />
                                            </WrapPanel>
                                        </Grid>

                                        <TextBlock x:Name="ContentText"
                                                   Text="{Binding Content}"
                                                   Style="{StaticResource Body}" />

                                        <TextBlock x:Name="MissingText"
                                                   Text="Missing translation content."
                                                   Style="{StaticResource Subtitle}"
                                                   FontStyle="Italic"
                                                   Visibility="Collapsed" />
                                    </StackPanel>

                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger
                                        Binding="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Missing}"
                                        Value="True">
                                        <Setter TargetName="ContentText" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="TranslationMetaPanel" Property="Visibility"
                                                Value="Collapsed" />
                                        <Setter TargetName="MissingText" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="ContainerBorder" Property="BorderBrush"
                                                Value="{StaticResource Brush.NotificationFailure}" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=OutOfDate}"
                                        Value="True">
                                        <Setter TargetName="ContainerBorder" Property="BorderBrush"
                                                Value="{StaticResource Brush.NotificationWarning}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>