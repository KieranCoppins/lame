<UserControl x:Class="Lame.Frontend.Views.AssetLibraryDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Lame.Frontend.ViewModels"
             xmlns:helpers="clr-namespace:Lame.Frontend.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance viewModels:AssetLibraryDetailsViewModel}">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Background="{StaticResource Brush.LightestGrey}">
        <Grid Margin="32">
            <StackPanel>
                <!-- Back Button -->
                <Button Command="{Binding ReturnToLibraryCommand}"
                        Style="{StaticResource ClickableText}">
                    <TextBlock Text="← Back to Asset Library"
                               FontSize="14"
                               Style="{StaticResource Link}"
                               Foreground="{StaticResource Brush.Primary}" />
                </Button>

                <ContentControl Content="{Binding AssetDetailsViewModel}" />

                <Button Command="{Binding ArchiveAssetCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource Brush.NotificationFailure}"
                        helpers:ButtonHelpers.HoverBackground="{StaticResource Brush.NotificationFailureHover }">
                    <TextBlock Style="{StaticResource Body}"
                               Text="Archive Asset"
                               Foreground="{StaticResource Brush.White}"
                               FontWeight="Bold" />
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>