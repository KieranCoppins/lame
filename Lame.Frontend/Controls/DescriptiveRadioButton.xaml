<RadioButton x:Class="Lame.Frontend.Controls.DescriptiveRadioButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <RadioButton.Template>
        <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Card"
                    Style="{StaticResource SmallCardBorderStyle}"
                    BorderThickness="2"
                    Cursor="Hand">

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0"
                          Width="16"
                          Height="16"
                          Margin="0,0,12,0">
                        <Ellipse Stroke="{StaticResource Brush.Primary}"
                                 StrokeThickness="2"
                                 Fill="Transparent" />

                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{StaticResource Brush.Primary}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">

                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                            Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                   Style="{StaticResource Header3}"
                                   Margin="0, 0, 0, 2"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="BodyTextBlock"
                                   Text="{Binding BodyText, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                   FontSize="12"
                                   Margin="0"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Subtitle}">
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding BodyText, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                            Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding BodyText, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                            Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource Brush.Grey}" />
                </Trigger>

                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource Brush.PrimaryHover}" />
                    <Setter TargetName="Card" Property="Background" Value="{StaticResource Brush.LightestGrey}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </RadioButton.Template>
</RadioButton>