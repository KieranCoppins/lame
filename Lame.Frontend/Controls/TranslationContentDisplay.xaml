<UserControl x:Class="Lame.Frontend.Controls.TranslationContentDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domainModel="clr-namespace:Lame.DomainModel;assembly=Lame.DomainModel"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>

        <!-- TEXT TEMPLATE -->
        <DataTemplate x:Key="TextTemplate">
            <TextBlock x:Name="TranslationContentControl"
                       Text="{Binding TranslationContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource Body}" />
        </DataTemplate>

        <!-- AUDIO TEMPLATE -->
        <DataTemplate x:Key="AudioTemplate">
            <Button Content="Download Audio"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding DownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding DownloadCommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <ContentControl>
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate" Value="{StaticResource TextTemplate}" />
                    <Style.Triggers>
                        <DataTrigger
                            Binding="{Binding AssetType, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Value="{x:Static domainModel:AssetType.Audio}">
                            <Setter Property="ContentTemplate" Value="{StaticResource AudioTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</UserControl>