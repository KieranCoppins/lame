<UserControl x:Class="Lame.Frontend.Controls.ChangeLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:domainModel="clr-namespace:Lame.DomainModel;assembly=Lame.DomainModel"
             mc:Ignorable="d"
             d:DesignHeight="1920" d:DesignWidth="1080">
    <ItemsControl ItemsSource="{Binding Entries, RelativeSource={RelativeSource AncestorType=UserControl}}">

        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0"
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Width="7"
                            Height="7"
                            CornerRadius="3.5"
                            Margin="8, 0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{StaticResource Brush.NotificationInfo}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResourceAction}"
                                                 Value="{x:Static domainModel:ResourceAction.Created }">
                                        <Setter Property="Background"
                                                Value="{StaticResource Brush.NotificationSuccess}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ResourceAction}"
                                                 Value="{x:Static domainModel:ResourceAction.Deleted }">
                                        <Setter Property="Background"
                                                Value="{StaticResource Brush.NotificationFailure}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Grid.Row="0">
                        <TextBlock Style="{StaticResource Body}"
                                   FontSize="13"
                                   Margin="0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="ResourceType" />
                                    <Binding Path="ResourceAction" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Grid.Row="0"
                               Style="{StaticResource Body}"
                               Foreground="{StaticResource Brush.DarkGrey}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0"
                               Text="{Binding Date, 
                                   Converter={StaticResource RelativeTimeConverter}}" />

                    <TextBlock
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Grid.Row="1"
                        Text="{Binding Message, Converter={StaticResource TabToSpaceConverter }}"
                        Style="{StaticResource Subtitle}"
                        FontSize="11"
                        Margin="0, 4, 0, 0"
                        TextWrapping="Wrap" />

                    <Border Style="{StaticResource SectionLineBorderStyle}"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Grid.Row="2" />
                </Grid>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>