<UserControl x:Class="Lame.Frontend.Controls.EditableText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <TextBlock x:Name="DisplayText"
                   Grid.Column="0"
                   Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />

        <TextBox x:Name="EditBox"
                 Grid.Column="0"
                 Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=LostFocus}"
                 Visibility="Collapsed"
                 Background="Transparent"
                 BorderThickness="0"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"
                 KeyDown="EditBox_KeyDown"
                 LostFocus="EditBox_OnLostFocus" />

        <Border x:Name="Underline"
                Grid.Column="0"
                Height="1"
                Background="{StaticResource Brush.Primary}"
                VerticalAlignment="Bottom"
                Visibility="Collapsed" />

        <TextBlock x:Name="PlaceholderTextBlock"
                   Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Grid.Column="0"
                   Foreground="{StaticResource Brush.DarkGrey}"
                   FontStyle="Italic" />
    </Grid>
</UserControl>